body {
  font-family: "Roboto Flex", sans-serif;
}

.titulo-playfair {
  font-family: "Playfair Display", serif;
}

.wave-right {
  opacity: 0;
  transform: translateX(200px);
  transition: opacity 1s ease, transform 1s ease;
}

.wave-left {
  opacity: 0;
  transform: translateX(-200px);
  transition: opacity 1s ease, transform 1s ease;
}

.wave-visible {
  opacity: 1;
  transform: translateX(0) !important;
}

